#bit5 MOUSE_ENABLE_PB_BUTTON_CONNECT_GND
#bit6 MOUSE_ENABLE_24G_FIRST_AUTO_PAIRING 
00
#mouse flag byte7
#bit0 MOUSE_ENABLE_AUTO_24G_PARING
#bit1 MOUSE_ENABLE_24G_POWER_ON_PAIRING
#bit2 MOUSE_ENABLE_COMMBINATION_KEY_BY_24G_PAIRING
