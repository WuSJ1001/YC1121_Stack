#bit1 MOUSE_ENABLE_BT_RECONN_LED_EFFECT
#bit2 MOUSE_ENABLE_LOW_LED_BLINK_LIMIT
#bit3 MOUSE_ENABLE_LOW_LED
#bit4 MOUSE_ENABLE_LOW_FOR_LED
