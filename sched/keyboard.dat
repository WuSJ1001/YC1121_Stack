#bit1 MOUSE_ENABLE_SELECT_DEVICE_BY_PB_BUTTON
#bit2 MOUSE_ENABLE_SELECT_DEVICE_BY_SWITCH_GPIO
#bit3 MOUSE_ENABLE_CUSTOMER_KEY_CONNECT_VIN_OR_MATRIX
