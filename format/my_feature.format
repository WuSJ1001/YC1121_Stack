

xmemalloc stack(
//UART串口通信RingBuff
16  mem_uart_rx_ringbuf
16  mem_uart_tx_ringbuf

//UART串口通信RingBuff地址
8   mem_pdatatemp

// UART 发送/接收临时变量
1   mem_my_uart_tx_byte
1   mem_my_uart_cmd0
1   mem_my_uart_cmd1

// 协议用“覆盖式堆栈”（16字节，满了继续push会覆盖最老数据）
16  mem_cmd_stack_space
1   mem_cmd_stack_top_idx
1   mem_cmd_stack_count

)

(

15  My_UART_RX_NUM
16  My_UART_TX_NUM

)
